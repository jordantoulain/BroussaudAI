# =============================================================================
# Configuration Supabase
# =============================================================================
SUPABASE_URL=your-supabase-project-url
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_CONNECTION_STRING=postgresql://postgres:your-password@aws-0-region.pooler.supabase.com:5432/postgres

# =============================================================================
# Configuration JWT (JSON Web Tokens)
# =============================================================================
# Générez une clé secrète forte avec : openssl rand -hex 32
JWT_SECRET=your-strong-jwt-secret-key-at-least-32-characters

# =============================================================================
# Configuration LLM (Large Language Models)
# =============================================================================
# Google GenAI (Gemini)
GOOGLE_API_KEY=your-google-genai-api-key

# MistralAI (optionnel, décommenter dans llm.py pour utiliser)
# MISTRAL_API_KEY=your-mistral-api-key

# Ollama (optionnel, décommenter dans llm.py pour utiliser)
# OLLAMA_BASE_URL=http://localhost:11434

# =============================================================================
# Configuration Docker
# =============================================================================
PORTS=8000
